<body>

<h2>選擇排序 (Selection Sort) - C 語言</h2>

<pre>
#include &lt;stdio.h&gt;

int main() {
    int arr[5] = {64, 25, 12, 22, 11};
    int i, j, min_idx, temp;

    for(i = 0; i < 5 - 1; i++) {
        min_idx = i;

        for(j = i + 1; j < 5; j++) {
            if(arr[j] < arr[min_idx]) {
                min_idx = j;
            }
        }

        temp = arr[min_idx];
        arr[min_idx] = arr[i];
        arr[i] = temp;
    }

    printf("排序後：");

    for(i = 0; i < 5; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
</pre>

